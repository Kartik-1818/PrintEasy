{
  "name": "printease",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c green,blue \"npm:dev -w server\" \"npm:dev -w client\"",
    "install:all": "npm install && npm install -w server && npm install -w client"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
